# Supabase PostgreSQL (porta 6543 = PgBouncer transaction mode)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# JWT Secret do Supabase (Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Porta do servidor
PORT=3333

# CORS origin (URL do frontend)
CORS_ORIGIN=https://tdah-portal.vercel.app

# Ambiente
NODE_ENV=development
