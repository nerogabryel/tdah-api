# Supabase PostgreSQL (porta 6543 = PgBouncer transaction mode)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# URL do projeto Supabase (para buscar JWKS de validação JWT)
SUPABASE_URL=https://qaqijtwrwdipvjlmnyxy.supabase.co

# JWT Secret legado do Supabase (fallback, opcional se JWKS funcionar)
SUPABASE_JWT_SECRET=

# Porta do servidor
PORT=3333

# CORS origin (URL do frontend)
CORS_ORIGIN=https://tdah-portal.vercel.app

# Ambiente
NODE_ENV=development
